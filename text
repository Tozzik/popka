--------Создание Бд:

Create table users (
   role varchar(150) check (role in ('Администратор', 'Менеджер', 'Авторизированный клиент')),
   full_name varchar(250) not null primary key,
   login varchar(150) not null,
   password varchar(150) not null
);

create table products (
   article varchar(100) primary key,
   name varchar(150) not null,
   unit varchar(50) default 'шт.',
   price decimal(10, 2),
   supplier varchar(100),
   namefacturer varchar(150) not null,
   category varchar(150),
   discount int check (discount >= 0),
   quancity int check (quancity >= 0),
   description text not null,
   photo text default 'picture.png'
);

create table pickup_points (
   id serial primary key,
   address varchar(255) not null
);

create table orders(
   id serial primary key,
   order_article varchar(255) not null,
   order_date date not null,
   dilivery_date date not null,
   address int references pickup_points(id),
   full_name varchar(150) references users(full_name),
   code int not null,
   status varchar(150) default 'Новый'
);



